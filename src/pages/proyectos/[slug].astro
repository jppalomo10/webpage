---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const proyectos = await getCollection('proyectos');
  return proyectos.map((proyecto) => ({
    params: { slug: proyecto.slug },
    props: { proyecto },
  }));
}

const { proyecto } = Astro.props;
const { Content } = await proyecto.render();
---

<Layout
  title={`${proyecto.data.title} — Juan Pablo Palomo`}
  description={proyecto.data.description}
  ogTitle={proyecto.data.title}
  ogDescription={proyecto.data.description}
>
  <div class="container article-page">
    <a href="/proyectos" class="back-link">
      <span class="es">← Todos los proyectos</span>
      <span class="en">← All projects</span>
    </a>

    <article>
      <header class="article-header">
        <h1 class="article-title">
          <span class="es">{proyecto.data.title}</span>
          <span class="en">{proyecto.data.titleEn ?? proyecto.data.title}</span>
        </h1>
        <p class="article-desc">
          <span class="es">{proyecto.data.description}</span>
          <span class="en">{proyecto.data.descriptionEn ?? proyecto.data.description}</span>
        </p>
        <div class="article-meta">
          {proyecto.data.stack.length > 0 && (
            <div class="entry-item__tags">
              {proyecto.data.stack.map((tech) => (
                <span class="tag">{tech}</span>
              ))}
            </div>
          )}
          {proyecto.data.github && (
            <a
              href={proyecto.data.github}
              target="_blank"
              rel="noopener noreferrer"
              class="project-github"
            >
              GitHub →
            </a>
          )}
        </div>
      </header>

      <div class="prose">
        <Content />
      </div>
    </article>
  </div>
</Layout>

<style>
  .article-page {
    padding-top: 4rem;
    padding-bottom: 6rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-muted);
    text-decoration: none;
    margin-bottom: 3rem;
    letter-spacing: 0.02em;
  }

  .back-link:hover {
    color: var(--color-fg);
    text-decoration: none;
  }

  .article-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .article-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .article-desc {
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.65;
    max-width: 60ch;
    margin-bottom: 1.25rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .project-github {
    font-size: 0.875rem;
    color: var(--color-muted);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .project-github:hover {
    color: var(--color-fg);
  }
</style>
