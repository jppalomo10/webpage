---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const dateEs = post.data.date.toLocaleDateString('es-GT', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const dateEn = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<Layout
  title={`${post.data.title} — Juan Pablo Palomo`}
  description={post.data.description}
  ogTitle={post.data.title}
  ogDescription={post.data.description}
>
  <div class="container article-page">
    <a href="/blog" class="back-link">
      <span class="es">← Todos los artículos</span>
      <span class="en">← All posts</span>
    </a>

    <article>
      <header class="article-header">
        <time datetime={post.data.date.toISOString()} class="article-date">
          <span class="es">{dateEs}</span>
          <span class="en">{dateEn}</span>
        </time>
        <h1 class="article-title">
          <span class="es">{post.data.title}</span>
          <span class="en">{post.data.titleEn ?? post.data.title}</span>
        </h1>
        {post.data.tags.length > 0 && (
          <div class="entry-item__tags" style="margin-top: 1rem;">
            {post.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <div class="prose">
        <Content />
      </div>
    </article>
  </div>
</Layout>

<style>
  .article-page {
    padding-top: 4rem;
    padding-bottom: 6rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-muted);
    text-decoration: none;
    margin-bottom: 3rem;
    letter-spacing: 0.02em;
  }

  .back-link:hover {
    color: var(--color-fg);
    text-decoration: none;
  }

  .article-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .article-date {
    display: block;
    font-size: 0.8rem;
    color: var(--color-subtle);
    margin-bottom: 0.75rem;
    letter-spacing: 0.02em;
  }

  .article-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
</style>
